{
  "regions": ["bom1"],
  "framework": "nextjs",
  "build": {
    "env": {
      "NODE_VERSION": "20"
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
